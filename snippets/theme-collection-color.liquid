{% assign current_collection = collection | default: product.collections.first %}

{% comment %} <style>
:root {
  --theme-bg: {{ current_collection.metafields.custom.color_themes.value | default: '#056839' }};

  --theme-bg-light:
    {{ current_collection.metafields.custom.color_themes.value | color_lighten: 10 }};

--theme-bg-dark:
  {{ current_collection.metafields.custom.color_themes.value | color_darken: 10 }};


  --theme-text:
    {{ current_collection.metafields.custom.menu_text_color.value | default: '#ffffff' }};

    --theme-subtitle: {{ collection.metafields.custom.theme_subtitle_color.value | default: '#A6CE39' }};

  --theme-bg-transparent:
    {{ current_collection.metafields.custom.color_themes.value
    | color_modify: 'alpha', 0.92 }};

  --theme-bg-light-transparent:
    {{ current_collection.metafields.custom.color_themes.value
    | color_lighten: 25
    | color_modify: 'alpha', 0.2 }};
}
</style> {% endcomment %}


<style>
:root {
  --theme-bg: {{ current_collection.metafields.custom.color_themes.value | default: '#056839' }};
}
</style>