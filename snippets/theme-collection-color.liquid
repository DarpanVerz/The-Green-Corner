{% assign current_collection = collection | default: product.collections.first %}

<style>
{% comment %} :root {
  --theme-bg: {{ current_collection.metafields.custom.menu_bg_color.value | default: '#056839' }};

  --theme-bg-light:
    {{ current_collection.metafields.custom.menu_bg_color.value | color_lighten: 10 }};

--theme-bg-dark:
  {{ current_collection.metafields.custom.menu_bg_color.value | color_darken: 10 }};


  --theme-text:
    {{ current_collection.metafields.custom.menu_text_color.value | default: '#ffffff' }};

    --theme-subtitle: {{ collection.metafields.custom.theme_subtitle_color.value | default: '#A6CE39' }};

  --theme-bg-transparent:
    {{ current_collection.metafields.custom.menu_bg_color.value
    | color_modify: 'alpha', 0.92 }};

  --theme-bg-light-transparent:
    {{ current_collection.metafields.custom.menu_bg_color.value
    | color_lighten: 25
    | color_modify: 'alpha', 0.2 }};
} {% endcomment %}
</style>