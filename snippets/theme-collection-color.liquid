<style>
:root {
  --theme-bg: {{ collection.metafields.custom.menu_bg_color.value | default: '#056839' }};
  --theme-bg-light: {{ collection.metafields.custom.menu_bg_color.value | color_lighten: 10 }};
  --theme-text: {{ collection.metafields.custom.menu_text_color.value | default: '#fff' }};
  --theme-bg-transparent: {{ collection.metafields.custom.menu_bg_color.value | color_modify: 'alpha', 0.92 }};
  --theme-bg-light-transparent: {{ collection.metafields.custom.menu_bg_color.value 
  | color_lighten: 25 
  | color_modify: 'alpha', 0.2 
}};
}
</style>