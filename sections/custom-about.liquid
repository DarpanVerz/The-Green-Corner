{% style %}
  .about-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
<section class="about-section">
  <div class="page-width about-wrapper">
    <div class="about-left">
      
      <p class="subtitle">{{ section.settings.subtitle }}</p>
      <h2 class="title">{{ section.settings.title }}</h2>
      <p class="desc">{{ section.settings.description }}</p>
      <a href="{{ section.settings.button_link }}" class="about-btn">
        {{ section.settings.button_text }}
      </a>
    </div>

    <div class="about-right">
      <div class="img-grid">
        <div class="img-large">
          {% if section.settings.image1 != blank %}
            <img src="{{ section.settings.image1 | img_url: 'master' }}" />
          {% endif %}
        </div>
        <div class="img-small">
          {% if section.settings.image2 != blank %}
            <img src="{{ section.settings.image2 | img_url: 'master' }}" />
          {% endif %}
        </div>
        <div class="img-small">
          {% if section.settings.image3 != blank %}
            <img src="{{ section.settings.image3 | img_url: 'master' }}" />
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom About Section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {"type": "text", "id": "subtitle", "label": "Subtitle", "default": "ABOUT US"},
    {"type": "text", "id": "title", "label": "Title", "default": "Creating a Supportive Environment"},
    {"type": "textarea", "id": "description", "label": "Description"},
    {"type": "text", "id": "button_text", "label": "Button Text", "default": "Learn Our Story"},
    {"type": "url", "id": "button_link", "label": "Button Link"},
    {"type": "image_picker", "id": "image1", "label": "Main Image"},
    {"type": "image_picker", "id": "image2", "label": "Top Right Image"},
    {"type": "image_picker", "id": "image3", "label": "Bottom Right Image"}
  ],
  "presets": [
    {"name": "Custom About Section"}
  ]
}
{% endschema %}