{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'section-products-grid.css' | asset_url | stylesheet_tag }}

<link
	rel="preload"
	href="{{ 'component-card.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>

<link
	rel="preload"
	href="{{ 'component-price.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>

<link
	rel="preload"
	href="{{ 'component-rte.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<script src="{{ 'products-grid.js' | asset_url }}" defer="defer"></script>

{%- if settings.quickview_show -%}
	<link
		rel="preload"
		href="{{ 'section-main-product.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>
	<link
		rel="stylesheet"
		href="{{ 'component-deferred-media.css' | asset_url }}"
		media="all"
	>
	<link
		rel="preload"
		href="{{ 'quick-add.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>

	<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
	<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if settings.quickview_show == false and settings.type_color_swatch == 'custom' -%}
	{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
	{% render 'section-padding' %}
{%- endstyle -%}

{% liquid
	assign grid_products = collections.all.products
	assign collection_handle = 'all'
	assign base_url = routes.all_products_collection_url
	assign total_shop_products = shop.products_count | default: 0

	if section.settings.collection != blank
		assign grid_products = section.settings.collection.products
		assign collection_handle = section.settings.collection.handle
		assign base_url = routes.collections_url | append: '/' | append: collection_handle
		assign total_shop_products = section.settings.collection.all_products_count
	endif

	if section.settings.product_list != blank
		assign grid_products = section.settings.product_list
		assign collection_handle = 'all'
		assign base_url = 'none'
		assign total_shop_products = section.settings.product_list.size
	endif

	case section.settings.sort
		when 'alphabetical', 'alphabetical_reversed'
			assign grid_products = grid_products | sort: 'title'
		when 'products_high', 'products_low'
			assign grid_products = grid_products | sort: 'price_min'
		when 'date', 'date_reversed'
			assign grid_products = grid_products | sort: 'published_at'
    when 'manual'
      assign grid_products = grid_products | sort: 'manual'
    when 'best-selling'
      assign grid_products = grid_products | sort: 'manual'
  endcase

	assign sort = section.settings.sort
 
	case section.settings.sort
		when 'alphabetical'
			assign sort ='title-ascending'
		when 'alphabetical_reversed'
			assign sort ='title-descending'
		when 'products_high'
			assign sort ='price-descending'
		when 'products_low'
			assign sort ='price-ascending'
		when 'date'
			assign sort ='created-ascending'
		when 'date_reversed'
			assign sort ='created-descending'
		else
			assign sort = 'manual'
	endcase

	if sort == 'price-descending' or sort == 'created-descending' or sort == 'title-descending'
		assign grid_products = grid_products | reverse
	endif

	assign is_dynamic_loading = false
  if total_shop_products > 50
    assign is_dynamic_loading = true
  elsif sort == 'manual' or sort == 'best-selling'
    if base_url != 'none'
      assign is_dynamic_loading = true
    endif
  endif.

	if is_dynamic_loading and base_url != 'none'
    assign sort_params = '?sort_by=' | append: sort
    # Using Section Rendering API https://shopify.dev/docs/api/ajax/section-rendering
    assign collection_url = base_url | append: sort_params | append: '&section_id=' | append: section.id
    assign grid_products = collection.products
  else
    assign collection_url = 'none'
  endif
%}

<div
	class="products-grid section-{{ section.id }}-padding{% if is_dynamic_loading %} products-grid--loading{% if collection.products.size > 0 %} products-grid--search-perfomed{% endif %}{% endif %} {{ total_shop_products }}"
	data-collection-url="{{ collection_url }}"
	data-is-dynamic-load="{{ is_dynamic_loading }}"
>
	<div class="container">
		<div class="section-grid">
			{% render 'section-header', text_size: 'large', section_heading_tag: section.settings.heading_tag %}

			<div class="products-grid full-width content">
				<ul
					id="products-grid"
					data-id="{{ section.id }}"
					class="collection-product-list {% if section.settings.show_two_cards %} collection-product-list--2-mobile{% endif %}"
				>
					{% if is_dynamic_loading == false or grid_products.size > 0 %}
						{%- for product in grid_products
							limit: section.settings.products_per_page
						-%}
							<li class="ggg collection-product-card {% if settings.quickview_hover and settings.slider_on_hover == false %}quickview--hover{% endif %}">
								{% render 'product-card',
									product_card_product: product,
									media_size: section.settings.image_ratio,
									media_fit: section.settings.image_fit,
									show_secondary_image: section.settings.show_secondary_image,
									show_vendor: section.settings.show_vendor,
									show_color_swatch: section.settings.show_color_swatch,
									show_desc: section.settings.show_desc,
									section_id: section.id,
									add_id: forloop.index,
									show_sku: section.settings.show_sku,
									text_alignment: settings.card_text_alignment
								%}
							</li>
						{%- endfor -%}
					{% else %}
						{%- for i in (1..4) -%}
							{% assign loop_index = forloop.index | modulo: 4 | plus: 1 %}
							<div class="popular-products__item_placeholder collection-popular-card collection-popular-card--placeholder">
								{% render 'product-card-placeholder',
									media_ratio: section.settings.image_ratio,
									show_vendor: section.settings.show_vendor,
									loop_index: loop_index
								%}
							</div>
						{%- endfor -%}
					{% endif %}
				</ul>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.products-grid.name",
	"tag": "section",
	"class": "products-grid-section",
	"disabled_on": {
		"templates": ["password"],
		"groups": ["*"]
	},
	"settings": [
		{
			"type": "collection",
			"id": "collection",
			"label": "t:sections.products-grid.settings.collection.label"
		},
		{
			"type": "product_list",
			"id": "product_list",
			"label": "t:sections.products-grid.settings.product_list.label",
			"info": "t:sections.products-grid.settings.product_list.info",
			"limit": 50
		},
		{
			"type": "paragraph",
			"content": "t:sections.products-grid.settings.text_about_products.content"
		},
		{
			"type": "paragraph",
			"content": "t:sections.products-grid.settings.text_about_dynamic.content"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"default": "t:sections.products-grid.settings.heading.default",
			"label": "t:sections.all.heading.label"
		},
		{
			"type": "select",
			"id": "heading_tag",
			"label": "t:sections.all.heading_tag.label",
			"options": [
				{
					"value": "h1",
					"label": "H1"
				},
				{
					"value": "h2",
					"label": "H2"
				},
				{
					"value": "h3",
					"label": "H3"
				},
				{
					"value": "h4",
					"label": "H4"
				},
				{
					"value": "h5",
					"label": "H5"
				},
				{
					"value": "h6",
					"label": "H6"
				},
				{
					"value": "div",
					"label": "div"
				},
				{
					"value": "p",
					"label": "p"
				}
			],
			"default": "h2"
		},
		{
			"type": "richtext",
			"id": "description",
			"default": "t:sections.products-grid.settings.description.default",
			"label": "t:sections.all.text.label"
		},
		{
			"type": "text_alignment",
			"id": "alignment",
			"label": "t:sections.all.content_alignment.label",
			"default": "center"
		},
		{
			"type": "range",
			"id": "products_per_page",
			"min": 4,
			"max": 50,
			"step": 1,
			"default": 8,
			"label": "t:sections.products-grid.settings.products_per_page.label"
		},
		{
			"type": "select",
			"id": "sort",
			"options": [
				{
					"value": "alphabetical",
					"label": "t:sections.products-grid.settings.sort.options__1.label"
				},
				{
					"value": "alphabetical_reversed",
					"label": "t:sections.products-grid.settings.sort.options__2.label"
				},
				{
					"value": "date_reversed",
					"label": "t:sections.products-grid.settings.sort.options__3.label"
				},
				{
					"value": "date",
					"label": "t:sections.products-grid.settings.sort.options__4.label"
				},
				{
					"value": "products_high",
					"label": "t:sections.products-grid.settings.sort.options__5.label"
				},
				{
					"value": "products_low",
					"label": "t:sections.products-grid.settings.sort.options__6.label"
				},
        {
          "value": "manual",
          "label": "t:sections.products-grid.settings.sort.options__7.label"
        },
        {
          "value": "best-selling",
          "label": "t:sections.products-grid.settings.sort.options__8.label"
        }
			],
			"default": "alphabetical",
			"label": "t:sections.products-grid.settings.sort.label",
      "info": "t:sections.products-grid.settings.sort.info"
		},
		{
			"type": "header",
			"content": "t:sections.all.product_card.header.content"
		},
		{
			"type": "checkbox",
			"id": "show_two_cards",
			"default": false,
			"label": "t:sections.all.product_card.mobile_card_count.label"
		},
		{
			"type": "checkbox",
			"id": "show_secondary_image",
			"default": true,
			"label": "t:sections.all.product_card.show_secondary_image.label"
		},
		{
			"type": "checkbox",
			"id": "show_sku",
			"default": false,
			"label": "t:sections.all.sku.show_sku"
		},
		{
			"type": "checkbox",
			"id": "show_vendor",
			"default": true,
			"label": "t:sections.all.product_card.show_vendor.label"
		},
		{
			"type": "checkbox",
			"id": "show_desc",
			"default": false,
			"label": "t:sections.all.product_card.show_description.label"
		},
		{
			"type": "checkbox",
			"id": "show_color_swatch",
			"default": false,
			"label": "t:sections.all.product_card.show_color.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.image.header.content"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "landscape",
					"label": "t:sections.all.image.ratio.options__1.label"
				},
				{
					"value": "portrait",
					"label": "t:sections.all.image.ratio.options__2.label"
				},
				{
					"value": "square",
					"label": "t:sections.all.image.ratio.options__3.label"
				}
			],
			"default": "portrait",
			"label": "t:sections.all.image.ratio.label"
		},
		{
			"type": "select",
			"id": "image_fit",
			"label": "t:sections.all.image.fit.label",
			"options": [
				{
					"value": "contain",
					"label": "t:sections.all.image.fit.options__1.label"
				},
				{
					"value": "cover",
					"label": "t:sections.all.image.fit.options__2.label"
				}
			],
			"default": "cover"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "xs",
					"label": "t:sections.all.section-padding.options__2.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.products-grid.name"
		}
	]
}
{% endschema %}
