<div class="blog-listing-section">
  <div class="container">

    <div class="blog-listing-header">

      <div class="blog-listing-left">

        {% if section.settings.subtitle != blank %}
          <div class="subtitle">
            {{ section.settings.subtitle }}
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2>
            {{ section.settings.heading }}
          </h2>
        {% endif %}

      </div>

      <div class="blog-listing-right">

        {% if section.settings.button_label != blank %}
          <div class="blog-view-all">
            {% render 'button',
              layout: section,
              btn_style: 'primary',
              btn_label: section.settings.button_label,
              btn_link: section.settings.button_link
            %}
          </div>
        {% endif %}

        <div class="blog-slider-arrows">
         <button class="blog-slider-btn blog-prev-{{ section.id }}">
  <svg viewBox="0 0 24 24" fill="none">
    <path d="M18 12H6"></path>
    <path d="M11 7L6 12L11 17"></path>
  </svg>
</button>

          <button class="blog-slider-btn blog-next-{{ section.id }}">
  <svg viewBox="0 0 24 24" fill="none">
    <path d="M6 12H18"></path>
    <path d="M13 7L18 12L13 17"></path>
  </svg>
</button>
        </div>

      </div>

    </div>

<div class="swiper blog-listing-slider-{{ section.id }}">
  <div class="swiper-wrapper">

    {% for article in section.settings.blog.articles limit: section.settings.posts_count %}
      
      <div class="swiper-slide">
        <div class="blog-slide-card">

          <div class="blog-slide-image">
            <a href="{{ article.url }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.title }}"
                  loading="lazy"
                >
              {% endif %}
            </a>
          </div>

          {% if section.settings.show_date %}
            <div class="blog-slide-date">
              {{ article.published_at | date: "%B %d, %Y" }}
            </div>
          {% endif %}

          <h3 class="blog-slide-title">
            <a href="{{ article.url }}">
              {{ article.title }}
            </a>
          </h3>

        </div>
      </div>

    {% endfor %}

  </div>
</div>

  </div>
</div>


<script>
document.addEventListener("DOMContentLoaded", function() {

  const blogSwiper = new Swiper(".blog-listing-slider-{{ section.id }}", {
    loop: true,
    speed: 800,
    slidesPerView: 4,
    spaceBetween: 28,

    navigation: {
      nextEl: ".blog-next-{{ section.id }}",
      prevEl: ".blog-prev-{{ section.id }}"
    },

    breakpoints: {
      0: {
        slidesPerView: 1,
        spaceBetween: 15
      },
      576: {
        slidesPerView: 2,
        spaceBetween: 18
      },
      768: {
        slidesPerView: 2,
        spaceBetween: 20
      },
      992: {
        slidesPerView: 3,
        spaceBetween: 24
      },
      1200: {
        slidesPerView: 4,
        spaceBetween: 28
      }
    }
  });

});
</script>

{% schema %}
{
  "name": "Custom Blog Listing",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "BLOG LISTING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cultivating Green Spaces, Enriching Lives Daily"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "posts_count",
      "label": "Posts Count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Blog Listing"
    }
  ]
}
{% endschema %}