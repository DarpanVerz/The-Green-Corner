<section class="floating-product-banner">
  <div class="page-width">
    <div class="floating-banner-wrapper">

      <!-- Background Image -->
      {% if section.settings.bg_image != blank %}
        {{
          section.settings.bg_image
          | image_url: width: 2500
          | image_tag:
            loading: 'lazy',
            class: 'floating-banner-image'
        }}
      {% endif %}

      <!-- Product Card -->
      {% assign product = all_products[section.settings.product] %}

      {% if product != blank %}
        <div
          class="floating-product-card"
          style="
            top: {{ section.settings.card_top }}%;
            left: {{ section.settings.card_left }}%;
          "
        >

          <div class="floating-product-inner">

            <div class="floating-product-image">
              {{
                product.featured_image
                | image_url: width: 200
                | image_tag: loading: 'lazy'
              }}
            </div>

            <div class="floating-product-content">
              <h3>{{ product.title }}</h3>

              <div class="floating-product-price">
                {{ product.price | money }}
              </div>
            </div>

          </div>

        </div>
      {% endif %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Floating Product Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    },
    {
      "type": "range",
      "id": "card_top",
      "label": "Product Card Top Position",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "card_left",
      "label": "Product Card Left Position",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 78,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Floating Product Banner"
    }
  ]
}
{% endschema %}