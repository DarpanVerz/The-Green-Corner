
<section class="testimonial-section">
  <div class="container page-width">
    <div class="ts-header">
      <p class="ts-subtitle">{{ section.settings.subtitle }}</p>
      <h2 class="ts-title">{{ section.settings.title }}</h2>
    </div>
  <div class="testimonial-slider swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide">
            <div class="testimonial-card">
              <div class="stars"> {% for i in (1..block.settings.rating) %} ★ {% endfor %}
              </div>
              <p class="content">
                "{{ block.settings.content }}"
              </p>
              <div class="profile">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | img_url: '100x100' }}" alt="">
                {% endif %}
                <div>
                  <h4>{{ block.settings.name }}</h4>
                  <span>{{ block.settings.designation }}</span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="swiper-button-prev testimonial-prev"></div>
      <div class="swiper-button-next testimonial-next"></div>
    </div>
  </div>
</section>

<style>
.testimonial-section {
  background: #F6E3D4;
  padding: 80px 0;
  border-radius: 30px;
  overflow: hidden;
  margin: 0px 20px;
}

.testimonial-slider {
  overflow: hidden;
  position: relative;
}

.testimonial-slider .swiper-slide {
  height: auto;
  box-sizing: border-box;
}

.testimonial-card {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/testimonial-bg.png');
    background-size: cover;
    background-position: bottom center;
    background-repeat: no-repeat;
    padding: 30px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.stars {
  color: #f5a623;
  font-size: 16px;
  margin-bottom: 15px;
}

.content {
  font-size: 15px;
  line-height: 1.7;
  color: #444;
  margin-bottom: 25px;
}

/* Profile */
.profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-left: 85px;
    position: relative;
    bottom: -25px;
}

.profile img {
  width: 45px;
  height: 45px;
  border-radius: 50%;
}

.profile h4 {
  font-size: 14px;
  margin: 0;
  font-weight: 600;
}

.profile span {
  font-size: 12px;
  color: #777;
}

/* HEADER */
.ts-header {
  text-align: center;
  margin-bottom: 50px;
}

.ts-subtitle {
  letter-spacing: 3px;
  color: #2e7d32;
  font-size: 13px;
}

.ts-title {
  font-size: 40px;
  margin-top: 10px;
  font-weight: 500;
}

.testimonial-slider .swiper-button-prev,
.testimonial-slider .swiper-button-next {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.testimonial-slider .swiper-button-prev {
  left: 10px;
}

.testimonial-slider .swiper-button-next {
  right: 10px;
}

.testimonial-slider .swiper-button-prev::after,
.testimonial-slider .swiper-button-next::after {
  font-size: 18px;
  color: #333;
  font-weight: bold;
}

.swiper-button-prev::after,
.swiper-button-next::after {
  font-size: 18px;
  color: #333;
  font-weight: bold;
}

.swiper-wrapper {
  align-items: stretch;
}

  .ts-title {
    font-size: 26px;
  }
}


.testimonial-slider .swiper-wrapper {
  align-items: stretch;
}


.testimonial-slider {
  overflow: hidden;
}

.testimonial-slider .swiper-slide {
  height: auto;
  box-sizing: border-box;
}

.testimonial-slider .swiper-wrapper {
  align-items: stretch;
}

.testimonial-slider {
  width: 100%;
}

.testimonial-slider .swiper-wrapper {
  display: flex;
}

.testimonial-slider .swiper-slide {
  flex-shrink: 0;
}

.testimonial-slider .swiper-button-prev {
  left: 5px;
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-slider-arrow.png');
  background-repeat: no-repeat;
  background-position: center;
  background-size: 22px;
}

.testimonial-slider .swiper-button-next {
  right: 5px;
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/slider-arrow.png');
  background-repeat: no-repeat;
  background-position: center;
  background-size: 22px;
}

.testimonial-slider .swiper-button-prev:hover,
.testimonial-slider .swiper-button-next:hover {
  background-color: #000000;
}

.testimonial-slider .swiper-button-prev:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-white-slider-arrow.png');
}

.testimonial-slider .swiper-button-next:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/right-white-slider-arrow.png');
}

.testimonial-slider .swiper-button-next svg path, .testimonial-slider .swiper-button-prev svg path { display:none !important; }

</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const testimonialSlider = document.querySelector(".testimonial-slider");

  if (!testimonialSlider) return;

  if (testimonialSlider.swiper) {
    testimonialSlider.swiper.destroy(true, true);
  }

  new Swiper(".testimonial-slider", {
  slidesPerView: 3,
  spaceBetween: 30,
  loop: false,
  watchOverflow: true,

  navigation: {
    nextEl: ".testimonial-next",
    prevEl: ".testimonial-prev",
  },

  breakpoints: {
    0: {
      slidesPerView: 1,
    },
    768: {
      slidesPerView: 2,
    },
    1024: {
      slidesPerView: 3,
    }
  }
});

});
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Hear From Our Plant Lovers"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Testimonial Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Profile Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "designation",
          "label": "Designation"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Testimonial Slider"
    }
  ]
}
{% endschema %}