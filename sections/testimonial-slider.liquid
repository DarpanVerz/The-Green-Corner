
<section class="testimonial-section">
  <div class="container-fluid">

    <!-- Header -->
    <div class="ts-header">
      <p class="ts-subtitle">{{ section.settings.subtitle }}</p>
      <h2 class="ts-title">{{ section.settings.title }}</h2>
    </div>

    <!-- Slider -->
    <div class="swiper testimonial-slider">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide">
            <div class="testimonial-card">

              <!-- Stars -->
              <div class="stars">
                {% for i in (1..block.settings.rating) %}
                  ★
                {% endfor %}
              </div>

              <!-- Content -->
              <p class="content">
                "{{ block.settings.content }}"
              </p>

              <!-- Profile -->
              <div class="profile">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | img_url: '100x100' }}" alt="">
                {% endif %}
                <div>
                  <h4>{{ block.settings.name }}</h4>
                  <span>{{ block.settings.designation }}</span>
                </div>
              </div>

            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Arrows -->
      <div class="swiper-button-prev testimonial-prev"></div>
      <div class="swiper-button-next testimonial-next"></div>
    </div>

  </div>
</section>

<style>
.testimonial-section {
  background: #F6E3D4;
  padding: 80px 0;
  border-radius: 30px;
  overflow: hidden;
  margin: 0px 20px;
}

.testimonial-slider {
  padding: 0 80px;
  position: relative;
}

.testimonial-slider .swiper-slide {
  height: auto;
  box-sizing: border-box;
}

.testimonial-card {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/testimonial-bg.png');
    background-size: cover;
    background-position: right center;
    background-repeat: no-repeat;
    padding: 30px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.stars {
  color: #f5a623;
  font-size: 16px;
  margin-bottom: 15px;
}

.content {
  font-size: 15px;
  line-height: 1.7;
  color: #444;
  margin-bottom: 25px;
}

/* Profile */
.profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-left: 60px;
    position: relative;
    bottom: -25px;
}

.profile img {
  width: 45px;
  height: 45px;
  border-radius: 50%;
}

.profile h4 {
  font-size: 14px;
  margin: 0;
  font-weight: 600;
}

.profile span {
  font-size: 12px;
  color: #777;
}

/* HEADER */
.ts-header {
  text-align: center;
  margin-bottom: 50px;
}

.ts-subtitle {
  letter-spacing: 3px;
  color: #2e7d32;
  font-size: 13px;
}

.ts-title {
  font-size: 40px;
  margin-top: 10px;
  font-weight: 500;
}

/* 🔥 PERFECT ARROWS */
.swiper-button-prev,
.swiper-button-next {
  width: 50px;
  height: 50px;
  background: #e7ded6;
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
}

.swiper-button-prev {
  left: 10px;
}

.swiper-button-next {
  right: 10px;
}

/* Arrow icon */
.swiper-button-prev::after,
.swiper-button-next::after {
  font-size: 18px;
  color: #333;
  font-weight: bold;
}

/* 🔥 SPACING BETWEEN CARDS */
.swiper-wrapper {
  align-items: stretch;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .testimonial-slider {
    padding: 0 40px;
  }
}

@media (max-width: 768px) {
  .testimonial-slider {
    padding: 0 20px;
  }

  .ts-title {
    font-size: 26px;
  }
}


.testimonial-slider .swiper-wrapper {
  align-items: stretch;
}

.testimonial-slider .swiper-slide {
  width: 100% !important;
}

.testimonial-slider {
  overflow: hidden;
}

.testimonial-slider .swiper-slide {
  box-sizing: border-box;
  height: auto;
}

.testimonial-slider .swiper-wrapper {
  align-items: stretch;
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const testimonialSlider = document.querySelector(".testimonial-slider");

  if (!testimonialSlider) return;

  // destroy if already initialized
  if (testimonialSlider.swiper) {
    testimonialSlider.swiper.destroy(true, true);
  }

  new Swiper(".testimonial-slider", {
    slidesPerView: 3,
    spaceBetween: 30,
    navigation: {
      nextEl: ".testimonial-next",
      prevEl: ".testimonial-prev",
    },

    breakpoints: {
      0: {
        slidesPerView: 1,
      },
      768: {
        slidesPerView: 2,
      },
      1024: {
        slidesPerView: 3,
      }
    }
  });

});
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Hear From Our Plant Lovers"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Testimonial Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Profile Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "designation",
          "label": "Designation"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Testimonial Slider"
    }
  ]
}
{% endschema %}