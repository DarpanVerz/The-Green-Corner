<section class="featured-products-section">

  <div class="featured-products-wrapper">

    <div class="featured-products-left">

      {% if section.settings.left_image != blank %}
        <img 
          src="{{ section.settings.left_image | image_url }}" 
          alt=""
          class="featured-products-left-image"
        >
      {% endif %}

      <div class="featured-products-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>

    </div>
    <div class="featured-products-right">

      <div class="swiper featuredProductsSlider">

        <div class="swiper-slide">

  <div class="featured-product-card">

    <div class="featured-product-image-wrapper">

      <a href="{{ product.url }}">
        <img 
          src="{{ product.featured_image | image_url }}" 
          alt="{{ product.title }}"
          class="featured-product-image"
        >
      </a>

      <div class="featured-product-overlay"></div>

      <div class="featured-product-hover-content">

        <div class="featured-product-buttons">

          <a href="/cart/add?id={{ product.selected_or_first_available_variant.id }}&quantity=1" class="featured-cart-btn">
            Add to Cart
          </a>

          <a href="{{ product.url }}" class="featured-view-btn">
            View Product
          </a>

        </div>

        <div class="featured-product-bottom-content">

          {% if product.compare_at_price > product.price %}
            <span class="featured-sale-text">Sale</span>
          {% endif %}

          <h3>{{ product.title }}</h3>

          <div class="featured-price-wrapper">

            <span class="featured-price">
              {{ product.price | money }}
            </span>

            {% if product.compare_at_price > product.price %}
              <span class="featured-compare-price">
                {{ product.compare_at_price | money }}
              </span>
            {% endif %}

          </div>

        </div>

      </div>

    </div>

  </div>

</div>

      </div>

       <div class="featured-products-next"> </div>
        <div class="featured-products-prev"> </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [

    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our handpicked flower bouquets, thoughtfully arranged to brighten any moment."
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }

  ],

  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}

<script>
document.addEventListener("DOMContentLoaded", function(){

  new Swiper(".featuredProductsSlider", {
    slidesPerView: 2,
    spaceBetween: 30,
    loop: true,

    navigation: {
      nextEl: ".featured-products-next",
      prevEl: ".featured-products-prev",
    },

    breakpoints: {
      0: {
        slidesPerView: 1
      },
      768: {
        slidesPerView: 2
      }
    }

  });

});
</script>


<style>

.featured-products-section{
  padding:60px 20px;
}

.featured-products-wrapper{
  display:flex;
  gap:20px;
  align-items:stretch;
}

.featured-products-left{
  width:35%;
  position:relative;
  overflow:hidden;
  border-radius:30px;
}

.featured-products-left::before{
  content:"";
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.45);
  z-index:1;
}

.featured-products-left-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.featured-products-content{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  width:100%;
  padding:0 30px;
  text-align:center;
  color:#fff;
  z-index:2;
}

.featured-products-content h2{
  font-size:48px;
  line-height:1.2;
  margin-bottom:15px;
  color:#fff;
}

.featured-products-content p{
  font-size:16px;
  line-height:1.6;
  color:#fff;
  max-width:400px;
  margin:0 auto;
}

.featured-products-right{
  width:65%;
  background:#fdecef;
  border-radius:30px;
  padding: 40px 60px;
  position:relative;
  overflow:hidden;
}

.featured-product-card{
  background:#fff;
  border-radius:25px;
  padding:30px;
}

.featured-product-image{
  width:100%;
  height:320px;
  object-fit:contain;
}

.featured-product-info{
  margin-top:20px;
}

.featured-product-info h3{
  font-size:24px;
  margin-bottom:10px;
}

.featured-product-info span{
  font-size:18px;
}

.featured-products-next,
.featured-products-prev{
  width:40px;
  height:40px;
  border-radius:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  z-index:9;
  cursor:pointer;
  font-size:24px;
}

.featured-products-next{
  right:10px;
}

.featured-products-prev{
  left:10px;
}

@media(max-width:991px){

  .featured-products-wrapper{
    flex-direction:column;
  }

  .featured-products-left,
  .featured-products-right{
    width:100%;
  }

  .featured-products-content h2{
    font-size:34px;
  }

}

.featured-products-prev {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    padding: 16px;
}

.featured-products-next {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    padding: 16px;
}

.featured-products-prev:hover,
.featured-products-next:hover {
  background-color: #000000;
}

.featured-products-prev:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-white-slider-arrow.png');
}

.featured-products-next:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/right-white-slider-arrow.png');
}

.featured-product-card{
  border-radius:30px;
  overflow:hidden;
  position:relative;
}

.featured-product-image-wrapper{
  position:relative;
  overflow:hidden;
  border-radius:30px;
  min-height:500px;
  background:#f5f5f5;
}

.featured-product-image{
  width:100%;
  height:500px;
  object-fit:contain;
  transition:0.4s ease;
  display:block;
}

/* overlay */

.featured-product-overlay{
  position:absolute;
  inset:0;
  background:rgba(1, 99, 46, 0.78);
  opacity:0;
  visibility:hidden;
  transition:0.4s ease;
  z-index:1;
}

/* hover content */

.featured-product-hover-content{
  position:absolute;
  inset:0;
  z-index:2;
  padding:25px 20px;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  opacity:0;
  visibility:hidden;
  transition:0.4s ease;
}

/* show on hover */

.featured-product-image-wrapper:hover .featured-product-overlay,
.featured-product-image-wrapper:hover .featured-product-hover-content{
  opacity:1;
  visibility:visible;
}

.featured-product-image-wrapper:hover .featured-product-image{
  transform:scale(1.05);
}

/* buttons */

.featured-product-buttons{
  display:flex;
  flex-direction:column;
  gap:12px;
  margin-bottom:30px;
}

.featured-cart-btn,
.featured-view-btn{
  height:52px;
  border-radius:50px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  font-size:16px;
  font-weight:500;
  transition:0.3s ease;
}

.featured-cart-btn{
  background:#fff;
  color:#000;
}

.featured-cart-btn:hover{
  background:#000;
  color:#fff;
}

.featured-view-btn{
  border:1px solid rgba(255,255,255,0.6);
  color:#fff;
  background:rgba(255,255,255,0.15);
  backdrop-filter:blur(4px);
}

.featured-view-btn:hover{
  background:#fff;
  color:#000;
}

/* bottom content */

.featured-sale-text{
  color:#ff5a5a;
  font-size:16px;
  font-weight:600;
  display:block;
  margin-bottom:10px;
}

.featured-product-bottom-content h3{
  font-size:28px;
  line-height:1.3;
  color:#fff;
  margin-bottom:14px;
}

.featured-price-wrapper{
  display:flex;
  align-items:center;
  gap:12px;
}

.featured-price{
  color:#ff5a5a;
  font-size:18px;
  font-weight:600;
}

.featured-compare-price{
  color:rgba(255,255,255,0.7);
  text-decoration:line-through;
  font-size:16px;
}

</style>
