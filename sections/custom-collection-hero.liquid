<section class="custom-collection-hero">
  <div class="hero-wrapper">

    <!-- Left Content -->
    <div class="hero-left">
      {% if section.settings.left_image != blank %}
        <img src="{{ section.settings.left_image | image_url }}" alt="">
      {% endif %}

      <div class="hero-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>
    </div>

    <!-- Right Collection Products -->
    <div class="hero-right">

      <div class="product-slider">
        {% for product in section.settings.collection.products limit: 2 %}
          
          <div class="product-card">

            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url }}" alt="{{ product.title }}">
            </a>

            <div class="product-info">
              <h3>{{ product.title }}</h3>
              <span>{{ product.price | money }}</span>
            </div>

          </div>

        {% endfor %}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Custom Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our handpicked flower bouquets, thoughtfully arranged to brighten any moment."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Hero"
    }
  ]
}
{% endschema %}
