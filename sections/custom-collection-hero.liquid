<section class="featured-products-section">

  <div class="featured-products-wrapper">

    <div class="featured-products-left">

      {% if section.settings.left_image != blank %}
        <img 
          src="{{ section.settings.left_image | image_url }}" 
          alt=""
          class="featured-products-left-image"
        >
      {% endif %}

      <div class="featured-products-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>

    </div>
    <div class="featured-products-right">

      <div class="swiper featuredProductsSlider">

        <div class="swiper-wrapper">

          {% for product in section.settings.collection.products %}

            <div class="swiper-slide">

              <div class="featured-product-card">

                <a href="{{ product.url }}">
                  <img 
                    src="{{ product.featured_image | image_url }}" 
                    alt="{{ product.title }}"
                    class="featured-product-image"
                  >
                </a>

                <div class="featured-product-info">
                  <h3>{{ product.title }}</h3>
                  <span>{{ product.price | money }}</span>
                </div>

              </div>

            </div>

          {% endfor %}

        </div>

        <div class="featured-products-next">
          →
        </div>

        <div class="featured-products-prev">
          ←
        </div>

      </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [

    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our handpicked flower bouquets, thoughtfully arranged to brighten any moment."
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }

  ],

  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}

<script>
document.addEventListener("DOMContentLoaded", function(){

  new Swiper(".featuredProductsSlider", {
    slidesPerView: 2,
    spaceBetween: 30,
    loop: true,

    navigation: {
      nextEl: ".featured-products-next",
      prevEl: ".featured-products-prev",
    },

    breakpoints: {
      0: {
        slidesPerView: 1
      },
      768: {
        slidesPerView: 2
      }
    }

  });

});
</script>


<style>

.featured-products-section{
  padding:60px 20px;
}

.featured-products-wrapper{
  display:flex;
  gap:20px;
  align-items:stretch;
}

.featured-products-left{
  width:35%;
  position:relative;
  overflow:hidden;
  border-radius:30px;
}

.featured-products-left::before{
  content:"";
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.45);
  z-index:1;
}

.featured-products-left-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.featured-products-content{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  width:100%;
  padding:0 30px;
  text-align:center;
  color:#fff;
  z-index:2;
}

.featured-products-content h2{
  font-size:48px;
  line-height:1.2;
  margin-bottom:15px;
  color:#fff;
}

.featured-products-content p{
  font-size:16px;
  line-height:1.6;
  color:#fff;
  max-width:400px;
  margin:0 auto;
}

.featured-products-right{
  width:65%;
  background:#fdecef;
  border-radius:30px;
  padding:40px;
  position:relative;
  overflow:hidden;
}

.featured-product-card{
  background:#fff;
  border-radius:25px;
  padding:30px;
}

.featured-product-image{
  width:100%;
  height:320px;
  object-fit:contain;
}

.featured-product-info{
  margin-top:20px;
}

.featured-product-info h3{
  font-size:24px;
  margin-bottom:10px;
}

.featured-product-info span{
  font-size:18px;
}

.featured-products-next,
.featured-products-prev{
  width:55px;
  height:55px;
  border-radius:100%;
  background:#111;
  color:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  z-index:9;
  cursor:pointer;
  font-size:24px;
}

.featured-products-next{
  right:10px;
}

.featured-products-prev{
  left:10px;
}

@media(max-width:991px){

  .featured-products-wrapper{
    flex-direction:column;
  }

  .featured-products-left,
  .featured-products-right{
    width:100%;
  }

  .featured-products-content h2{
    font-size:34px;
  }

}

.pagination__item-arrow span {
    left: 5px;
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    border-radius: 50px;
    width: 40px;
    height: 40px;
    padding: 16px;
}

.featured-products-next {
    left: 5px;
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    border-radius: 50px;
    width: 40px;
    height: 40px;
    padding: 16px;
}

.pagination__item--current {
    border: none !important;
    color: #056839 !important;
    font-weight: 600 !important;
}

.pagination__item:not(.pagination__item--current):hover, .pagination__item:focus {
    border: 1px solid #ccc !important;
}

.pagination__item-arrow span:hover,
featured-products-next:hover {
  background-color: #000000;
}

.pagination__item-arrow span:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-white-slider-arrow.png');
}

featured-products-next:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/right-white-slider-arrow.png');
}

</style>
