<section class="featured-products-section">

{%- liquid
  assign nav_menu = linklists['main-menu']
  assign featured_collection = section.settings.collection
  assign matched_parent = nil
  assign current_path = featured_collection.url

  for link in nav_menu.links
    if link.object.handle == featured_collection.handle or link.url == current_path
      assign matched_parent = link
    endif

    unless matched_parent
      for l2 in link.links
        if l2.object.handle == featured_collection.handle or l2.url == current_path
          assign matched_parent = link
        endif

        unless matched_parent
          for l3 in l2.links
            if l3.object.handle == featured_collection.handle or l3.url == current_path
              assign matched_parent = link
            endif

            unless matched_parent
              for l4 in l3.links
                if l4.object.handle == featured_collection.handle or l4.url == current_path
                  assign matched_parent = link
                endif
              endfor
            endunless
          endfor
        endunless
      endfor
    endunless
  endfor

  assign featured_accent_color = matched_parent.object.metafields.custom.menu_bg_color.value | default: '#056839'
-%}

  <div class="featured-products-wrapper">

    <div class="featured-products-left">

      {% if section.settings.left_image != blank %}
        <img 
          src="{{ section.settings.left_image | image_url }}" 
          alt=""
          class="featured-products-left-image"
        >
      {% endif %}

      <div class="featured-products-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>

    </div>
    <div class="featured-products-right">

      <div class="swiper featuredProductsSlider">

        <div class="swiper-wrapper">

          {% for product in section.settings.collection.products %}

            <div class="swiper-slide">

              <div class="featured-product-card card-wrapper" style="--hover-color: {{ featured_accent_color | color_modify: 'alpha', 0.9 }};
   --button-color: {{ featured_accent_color | color_modify: 'alpha', 0.3 }};
   --button-border-color: {{ featured_accent_color | color_darken: 10 }};">

                <div class="custom-hover-buttons">
  <product-form class="hover-product-form">

  {%- form 'product',
    product,
    class: 'form',
    novalidate: 'novalidate',
    data-type: 'add-to-cart-form'
  -%}

    <input
      type="hidden"
      name="id"
      value="{{ product.selected_or_first_available_variant.id }}"
    >

    <button
      type="submit"
      name="add"
      class="hover-cart-btn"
      {% if product.selected_or_first_available_variant.available == false %}
        disabled
      {% endif %}
    >
      <span>Add to Cart</span>

      <b class="loading-overlay__spinner hidden">
        <svg
          aria-hidden="true"
          focusable="false"
          role="presentation"
          class="spinner"
          viewBox="0 0 66 66"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle
            class="path"
            fill="none"
            stroke-width="6"
            cx="33"
            cy="33"
            r="30"
          ></circle>
        </svg>
      </b>

    </button>

  {%- endform -%}

</product-form>

<a href="{{ product.url }}" class="hover-view-btn">
  View Product
</a>

</div>

                <a href="{{ product.url }}">
                  <img 
                    src="{{ product.featured_image | image_url }}" 
                    alt="{{ product.title }}"
                    class="featured-product-image"
                  >
                </a>

                <div class="featured-product-info card-information left">
                  <h3 class="card__title">{{ product.title }}</h3> <br>
                  <span class="price-item price-item--regular">{{ product.price | money }}</span>
                </div>

              </div>

            </div>

          {% endfor %}

        </div>

      </div>

       <div class="featured-products-next"> </div>
        <div class="featured-products-prev"> </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [

    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our handpicked flower bouquets, thoughtfully arranged to brighten any moment."
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }

  ],

  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}

<script>
document.addEventListener("DOMContentLoaded", function(){

  new Swiper(".featuredProductsSlider", {
    slidesPerView: 2,
    spaceBetween: 30,
    loop: true,

    navigation: {
      nextEl: ".featured-products-next",
      prevEl: ".featured-products-prev",
    },

    breakpoints: {
      0: {
        slidesPerView: 1
      },
      768: {
        slidesPerView: 2
      }
    }

  });

});
</script>


<style>

.featured-products-section{
  padding:60px 20px;
}

.featured-products-wrapper{
  display:flex;
  gap:20px;
  align-items:stretch;
}

.featured-products-left{
  width:35%;
  position:relative;
  overflow:hidden;
  border-radius:30px;
}

.featured-products-left::before{
  content:"";
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.45);
  z-index:1;
}

.featured-products-left-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.featured-products-content{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  width:100%;
  padding:0 30px;
  text-align:center;
  color:#fff;
  z-index:2;
}

.featured-products-content h2{
  font-size:48px;
  line-height:1.2;
  margin-bottom:15px;
  color:#fff;
}

.featured-products-content p{
  font-size:16px;
  line-height:1.6;
  color:#fff;
  max-width:400px;
  margin:0 auto;
}

.featured-products-right{
  width:65%;
  background:#FFE6ED;
  border-radius:30px;
  padding: 40px 60px;
  position:relative;
  overflow:hidden;
}

.featured-product-card {
  background:#fff;
  border-radius:25px;
  padding:30px;
  position:relative;
}

.featured-product-image{
  width:100%;
  height:320px;
  object-fit:contain;
}

.featured-product-info{
  margin-top:20px;
}

.featured-product-info h3{
  font-size:24px;
  margin-bottom:10px;
}

.featured-product-info span{
  font-size:18px;
}

.featured-products-next,
.featured-products-prev{
  width:40px;
  height:40px;
  border-radius:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  z-index:9;
  cursor:pointer;
  font-size:24px;
}

.featured-products-next{
  right:10px;
}

.featured-products-prev{
  left:10px;
}

@media(max-width:991px){

  .featured-products-wrapper{
    flex-direction:column;
  }

  .featured-products-left,
  .featured-products-right{
    width:100%;
  }

  .featured-products-content h2{
    font-size:34px;
  }

}

.featured-products-prev {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    padding: 16px;
}

.featured-products-next {
    background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/slider-arrow.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 17px;
    border: #ccc solid 1px;
    padding: 16px;
}

.featured-products-prev:hover,
.featured-products-next:hover {
  background-color: #000000;
}

.featured-products-prev:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/left-white-slider-arrow.png');
}

.featured-products-next:hover {
  background-image: url('https://cdn.shopify.com/s/files/1/0757/6767/7120/files/right-white-slider-arrow.png');
}

.card-wrapper:hover .card__title {
    color: #fff;
}

.card-wrapper .card__title {
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    line-height: 27px;
    display: inline-block;
    padding:0; 
}

</style>
