			"type": "text",
			"name": "t:sections.rich-text.blocks.text.name",
			"limit": 2,
			"settings": [
				{
					"type": "richtext",
					"id": "text",
					"default": "t:sections.rich-text.blocks.text.settings.text.default",
					"label": "t:sections.all.text.label"
				},
				{
