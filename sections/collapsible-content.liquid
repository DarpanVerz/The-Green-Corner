{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collapsible-content.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-padding' %}
		{% render 'section-margin' %}
{%- endstyle -%}

<link
	rel="stylesheet"
	href="{{ 'component-accordion.css' | asset_url }}"
	media="print"
	onload="this.media='all'"
>

<div class="collapsible-content faq-section section-{{ section.id }}-padding  background {% if section.settings.enable_border_top %} section_border_top{% endif %}{% if section.settings.enable_border_bottom %} section_border_bottom{% endif %}">
	<div class="container">
		<div class="collapsible-content-wrapper custom-collapsible">
			{% if section.settings.heading != blank
				or section.settings.description != blank
			%}


				<div 
  class="collapsible-content__title-box"
  style="text-align: {{ section.settings.text_alignment }};"
>
  
  {%- if section.settings.heading != blank -%}
    <{{ section.settings.heading_tag }} class="collapsible-content__title h3">
      {{ section.settings.heading }}
    </{{ section.settings.heading_tag }}>
  {%- endif -%}

  {%- if section.settings.description != blank -%}
    <div class="collapsible-content-desc richtext__content extra-large-font">
      {{ section.settings.description }}
    </div>
  {%- endif -%}

</div>



			{%- endif -%}

			<div class="collapsible-content-box">
				{% for block in section.blocks %}
					{% if block.settings.block_heading != blank
						and block.settings.text != blank
					%}
						<div class="collapsible-content-block">
							<div class="collapsible-content-item">
								<div class="collapsible-content-summery">
									<{{ block.settings.block_heading_tag }} class="collapsible-content-block__heading h4">
										{{ block.settings.block_heading }}
									</{{ block.settings.block_heading_tag }}>
									<div class="custom-arrow-btn">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										aria-hidden="true"
									>
										<path
										d="M12 5V19"
										stroke="currentColor"
										stroke-width="1.7"
										stroke-linecap="round"
										/>
										<path
										d="M6 13L12 19L18 13"
										stroke="currentColor"
										stroke-width="1.7"
										stroke-linecap="round"
										stroke-linejoin="round"
										/>
									</svg>
									</div>
								</div>
								{%- if block.settings.text != blank -%}
									<div
										class="collapsible-content-block__description large-font richtext__content "
										{% if forloop.index != 1 %}
											style="display: none"
										{% endif %}
									>
										{{ block.settings.text }}
									</div>
								{%- endif -%}
							</div>
						</div>
					{%- endif -%}
				{% endfor %}
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.collapsible-content.name",
	"class": "collapsible-content-section",
	"tag": "section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-1",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"default": "t:sections.collapsible-content.settings.heading.default",
			"label": "t:sections.all.heading.label"
		},
		{
			"type": "select",
			"id": "heading_tag",
			"label": "t:sections.all.heading_tag.label",
			"options": [
				{
					"value": "h1",
					"label": "H1"
				},
				{
					"value": "h2",
					"label": "H2"
				},
				{
					"value": "h3",
					"label": "H3"
				},
				{
					"value": "h4",
					"label": "H4"
				},
				{
					"value": "h5",
					"label": "H5"
				},
				{
					"value": "h6",
					"label": "H6"
				},
				{
					"value": "div",
					"label": "div"
				},
				{
					"value": "p",
					"label": "p"
				}
			],
			"default": "h3"
		},
		{
			"type": "inline_richtext",
