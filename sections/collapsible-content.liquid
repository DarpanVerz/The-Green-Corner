					"id": "text",
					"default": "t:sections.collapsible-content.blocks.settings.text.default",
					"label": "t:sections.all.text.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.collapsible-content.name",
			"blocks": [
