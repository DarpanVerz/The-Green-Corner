
{% render 'theme-collection-color' %}

{% comment %}
  SECTION: custom-product-tabs.liquid
{% endcomment %}

<section class="container-fluid">

  <div class="product-tabs-section">

    <div class="page-width"> 

    <div class="product-tabs-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="product-tabs-buttons">
      {% if product.metafields.custom.information != blank %}
        <button class="tab-btn active" data-tab="info">
          {{ section.settings.information_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.care_instructions != blank %}
        <button class="tab-btn" data-tab="care">
          {{ section.settings.care_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.delivery_info != blank %}
        <button class="tab-btn" data-tab="delivery">
          {{ section.settings.delivery_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.reviews != blank %}
        <button class="tab-btn" data-tab="review">
          {{ section.settings.review_title }}
        </button>
      {% endif %}
    </div>

    <div class="product-tabs-wrapper">

      <div class="product-tabs-content">

        {% if product.metafields.custom.information != blank %}
          <div class="tab-content active" id="info">
            <div class="product-col-content">
              <div class="product-information-content">
                {{ product.metafields.custom.information | metafield_tag }}
              </div>
                <div class="product-tabs-image">
                  {% if product.metafields.custom.tab_image != blank %}
                    {{
                      product.metafields.custom.tab_image
                      | image_url: width: 700
                      | image_tag: loading: 'lazy'
                    }}
                  {% else %}
                    {{
                      product.featured_image
                      | image_url: width: 700
                      | image_tag: loading: 'lazy'
                    }}
                  {% endif %}
                </div>
            </div>
          </div>
        {% endif %}

        {% if product.metafields.custom.care_instructions != blank %}
          <div class="tab-content" id="care">
            {{ product.metafields.custom.care_instructions | metafield_tag }}
          </div>
        {% endif %}

        {% if product.metafields.custom.delivery_info != blank %}
          <div class="tab-content" id="delivery">
            {{ product.metafields.custom.delivery_info | metafield_tag }}
          </div>
        {% endif %}

        {% if product.metafields.custom.reviews != blank %}
          <div class="tab-content" id="review">
            {{ product.metafields.custom.reviews | metafield_tag }}
          </div>
        {% endif %}

      </div>

    </div>

    </div>

  </div>

</section>

<style>



</style>

<script>

document.addEventListener('DOMContentLoaded', function () {

  const buttons = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  buttons.forEach(button => {

    button.addEventListener('click', function () {

      const tab = this.getAttribute('data-tab');

      buttons.forEach(btn => btn.classList.remove('active'));
      contents.forEach(content => content.classList.remove('active'));

      this.classList.add('active');

      document.getElementById(tab).classList.add('active');

    });

  });

});

</script>

{% schema %}
{
  "name": "Product Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "About the Product"
    },
    {
      "type": "text",
      "id": "information_title",
      "label": "Information Tab Title",
      "default": "Information"
    },
    {
      "type": "text",
      "id": "care_title",
      "label": "Care Instructions Tab Title",
      "default": "Care Instructions"
    },
    {
      "type": "text",
      "id": "delivery_title",
      "label": "Delivery Info Tab Title",
      "default": "Delivery Info"
    },
    {
      "type": "text",
      "id": "review_title",
      "label": "Review Tab Title",
      "default": "Reviews"
    }
  ],
  "presets": [
    {
      "name": "Product Tabs"
    }
  ]
}
{% endschema %}