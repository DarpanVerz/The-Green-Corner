
{% render 'theme-collection-color' %}

{% comment %}
  SECTION: custom-product-tabs.liquid
{% endcomment %}

<section class="container-fluid">

  <div class="product-tabs-section">

    <div class="page-width"> 

    <div class="product-tabs-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="product-tabs-buttons">
      {% if product.metafields.custom.information != blank %}
        <button class="tab-btn active" data-tab="info">
          {{ section.settings.information_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.care_instructions != blank %}
        <button class="tab-btn" data-tab="care">
          {{ section.settings.care_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.delivery_info != blank %}
        <button class="tab-btn" data-tab="delivery">
          {{ section.settings.delivery_title }}
        </button>
      {% endif %}

      {% if product.metafields.custom.reviews != blank %}
        <button class="tab-btn" data-tab="review">
          {{ section.settings.review_title }}
        </button>
      {% endif %}
    </div>

    <div class="product-tabs-wrapper">

      <div class="product-tabs-content">

        {% if product.metafields.custom.information != blank %}
          <div class="tab-content active" id="info">
            <div class="product-col-content">
              <div class="product-information-content">
                {{ product.metafields.custom.information | metafield_tag }}
              </div>
                <div class="product-tabs-image">
                  {% if product.metafields.custom.tab_image != blank %}
                    {{
                      product.metafields.custom.tab_image
                      | image_url: width: 700
                      | image_tag: loading: 'lazy'
                    }}
                  {% else %}
                    {{
                      product.featured_image
                      | image_url: width: 700
                      | image_tag: loading: 'lazy'
                    }}
                  {% endif %}
                </div>
            </div>
          </div>
        {% endif %}

        {% if product.metafields.custom.care_instructions != blank %}
          <div class="tab-content" id="care">
            {{ product.metafields.custom.care_instructions | metafield_tag }}
          </div>
        {% endif %}

        {% if product.metafields.custom.delivery_info != blank %}
          <div class="tab-content" id="delivery">
            {{ product.metafields.custom.delivery_info | metafield_tag }}
          </div>
        {% endif %}

        {% if product.metafields.custom.reviews != blank %}
          <div class="tab-content" id="review">
            {{ product.metafields.custom.reviews | metafield_tag }}
          </div>
        {% endif %}

      </div>

    </div>

    </div>

  </div>

</section>

<style>

.product-tabs-section {
  background-color: var(--theme-bg);
  padding: 80px 0;
  border-radius: 30px;
  margin-top: 60px;
}

.product-tabs-heading {
  text-align: center;
  margin-bottom: 35px;
}

.product-tabs-heading h2 {
  font-size: 50px;
  font-weight: 500;
  color: var(--theme-text);
  margin: 0;
}

.product-tabs-buttons {
  display: flex;
  justify-content: center;
  gap: 14px;
  margin-bottom: 50px;
  flex-wrap: wrap;
}

.product-tabs-buttons .tab-btn {
  border: 0;
  background: #fff;
  color: #555;
  padding: 12px 24px;
  border-radius: 40px;
  cursor: pointer;
  font-size: 14px;
  transition: 0.3s ease;
  min-width: 140px;
}

.product-tabs-buttons .tab-btn.active {
  background: #0a7a43;
  color: #fff;
}

.product-tabs-buttons .tab-btn:hover {
  background-color: var(--theme-bg-light-transparent);
  color: var(--theme-text);
}

.product-tabs-wrapper {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 60px;
}

.product-col-content {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 60px;
}

.product-tabs-content {
  width: 100%;
}

.product-information-content {  width: 50%; }

.product-tabs-image { width: 50%; }

.product-tabs-image img {
  width: 100%;
  border-radius: 24px;
  display: block;
  height: auto;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

.product-tabs-content h1,
.product-tabs-content h2,
.product-tabs-content h3,
.product-tabs-content h4 {
  margin-top: 0;
  color: var(--theme-text);
}

.product-tabs-content p {
  font-size: 16px;
  line-height: 1.8;
  color: var(--theme-text);
}

.product-tabs-content ul {
  padding-left: 20px;
  margin-top: 20px;
}

.product-tabs-content li {
  margin-bottom: 10px;
  color: var(--theme-text);
  width: 50%;
  display: inline-block;
  position: relative; 
}

.product-tabs-content li:before {
    content: '';
    background: #A6CE39;
    width: 10px;
    height: 10px;
    border-radius: 50px;
    position: absolute;
    left: -20px;
    top: 4px;
}

@media screen and (max-width: 991px) {

  .product-col-content {
    flex-direction: column;
  }

  .product-information-content,
  .product-tabs-image {
    width: 100%;
  }

  .product-tabs-heading h2 {
    font-size: 32px;
  }

}

</style>

<script>

document.addEventListener('DOMContentLoaded', function () {

  const buttons = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  buttons.forEach(button => {

    button.addEventListener('click', function () {

      const tab = this.getAttribute('data-tab');

      buttons.forEach(btn => btn.classList.remove('active'));
      contents.forEach(content => content.classList.remove('active'));

      this.classList.add('active');

      document.getElementById(tab).classList.add('active');

    });

  });

});

</script>

{% schema %}
{
  "name": "Product Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "About the Product"
    },
    {
      "type": "text",
      "id": "information_title",
      "label": "Information Tab Title",
      "default": "Information"
    },
    {
      "type": "text",
      "id": "care_title",
      "label": "Care Instructions Tab Title",
      "default": "Care Instructions"
    },
    {
      "type": "text",
      "id": "delivery_title",
      "label": "Delivery Info Tab Title",
      "default": "Delivery Info"
    },
    {
      "type": "text",
      "id": "review_title",
      "label": "Review Tab Title",
      "default": "Reviews"
    }
  ],
  "presets": [
    {
      "name": "Product Tabs"
    }
  ]
}
{% endschema %}