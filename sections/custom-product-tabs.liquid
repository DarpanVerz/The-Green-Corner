

<section class="ap-product-tabs-section">
  <div class="ap-product-tabs-wrapper">

    <div class="ap-product-tabs-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="ap-product-tabs-buttons">
      {% for block in section.blocks %}
        <button
          class="ap-product-tab-btn {% if forloop.first %}active{% endif %}"
          type="button"
          data-tab="tab-{{ block.id }}"
        >
          {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      <div
        class="ap-product-tab-content {% if forloop.first %}active{% endif %}"
        id="tab-{{ block.id }}"
      >
        <div class="ap-product-tab-grid">

          <div class="ap-product-tab-left">
            <h3>{{ product.metafields.custom.tab1_heading }}</h3>

            <div class="ap-product-desc">
             {{ product.metafields.custom.tab1_description }}
            </div>

            {% if block.settings.list_1 != blank or block.settings.list_2 != blank or block.settings.list_3 != blank or block.settings.list_4 != blank %}
              <ul>
                {{ product.metafields.custom.tab1_title }}

                {% if block.settings.list_2 != blank %}
                  <li>{{ block.settings.list_2 }}</li>
                {% endif %}

                {% if block.settings.list_3 != blank %}
                  <li>{{ block.settings.list_3 }}</li>
                {% endif %}

                {% if block.settings.list_4 != blank %}
                  <li>{{ block.settings.list_4 }}</li>
                {% endif %}
              </ul>
            {% endif %}
          </div>

          <div class="ap-product-tab-right">
          {{ product.metafields.custom.tab1_image | image_url: width: 900 }}
          </div>

        </div>
      </div>
    {% endfor %}

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('.ap-product-tabs-section');

    if (!section) return;

    const buttons = section.querySelectorAll('.ap-product-tab-btn');
    const contents = section.querySelectorAll('.ap-product-tab-content');

    buttons.forEach((button) => {
      button.addEventListener('click', function () {
        const tabId = this.getAttribute('data-tab');

        buttons.forEach((btn) => btn.classList.remove('active'));
        contents.forEach((content) => content.classList.remove('active'));

        this.classList.add('active');

        const activeContent = section.querySelector('#' + tabId);

        if (activeContent) {
          activeContent.classList.add('active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "AP Product Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "About the Product"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Button Title",
          "default": "Information"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Content Title",
          "default": "About Cute Pink Rose"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Add your product description here.</p>"
        },
        {
          "type": "text",
          "id": "list_1",
          "label": "List Item 1"
        },
        {
          "type": "text",
          "id": "list_2",
          "label": "List Item 2"
        },
        {
          "type": "text",
          "id": "list_3",
          "label": "List Item 3"
        },
        {
          "type": "text",
          "id": "list_4",
          "label": "List Item 4"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Right Side Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AP Product Tabs",
      "blocks": [
        {
          "type": "tab"
        },
        {
          "type": "tab"
        },
        {
          "type": "tab"
        },
        {
          "type": "tab"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .ap-product-tabs-section {
    padding: 60px 20px;
  }

  .ap-product-tabs-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    background: #f8dfe8;
    border-radius: 30px;
    padding: 60px;
  }

  .ap-product-tabs-heading {
    text-align: center;
    margin-bottom: 35px;
  }

  .ap-product-tabs-heading h2 {
    font-size: 52px;
    line-height: 1.2;
    color: #2f2f2f;
    margin: 0;
    font-family: Georgia, serif;
    font-weight: 400;
  }

  .ap-product-tabs-buttons {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 50px;
  }

  .ap-product-tab-btn {
    padding: 12px 28px;
    border-radius: 40px;
    border: none;
    cursor: pointer;
    background: #ffffff;
    color: #555;
    font-size: 14px;
    font-weight: 500;
    transition: 0.3s ease;
  }

  .ap-product-tab-btn.active {
    background: #0c7a43;
    color: #fff;
  }

  .ap-product-tab-content {
    display: none;
  }

  .ap-product-tab-content.active {
    display: block;
  }

  .ap-product-tab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ap-product-tab-left h3 {
    font-size: 42px;
    line-height: 1.2;
    margin-bottom: 25px;
    color: #2f2f2f;
    font-family: Georgia, serif;
    font-weight: 400;
  }

  .ap-product-tab-left .ap-product-desc {
    font-size: 16px;
    line-height: 1.8;
    color: #4d4d4d;
    margin-bottom: 25px;
  }

  .ap-product-tab-left ul {
    margin: 0;
    padding-left: 20px;
  }

  .ap-product-tab-left ul li {
    margin-bottom: 12px;
    color: #333;
    font-size: 15px;
  }

  .ap-product-tab-right {
    position: relative;
  }

  .ap-product-tab-right img {
    width: 100%;
    border-radius: 28px;
    display: block;
  }

  .ap-product-tab-right::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 160px;
    border-radius: 0 0 28px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
    pointer-events: none;
  }

  @media screen and (max-width: 991px) {
    .ap-product-tabs-wrapper {
      padding: 40px 25px;
    }

    .ap-product-tab-grid {
      grid-template-columns: 1fr;
      gap: 35px;
    }

    .ap-product-tab-left h3 {
      font-size: 32px;
    }

    .ap-product-tabs-heading h2 {
      font-size: 40px;
    }
  }

  @media screen and (max-width: 767px) {
    .ap-product-tabs-wrapper {
      padding: 30px 20px;
      border-radius: 20px;
    }

    .ap-product-tabs-heading h2 {
      font-size: 30px;
    }

    .ap-product-tab-left h3 {
      font-size: 26px;
    }

    .ap-product-tab-btn {
      width: 100%;
    }
  }
</style>

