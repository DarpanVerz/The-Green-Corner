<section class="ap-product-tabs-section">

    {% for block in section.blocks %}
      <div
        class="ap-product-tab-content {% if forloop.first %}active{% endif %}"
        id="tab-{{ block.id }}"
      >
        <div class="ap-product-tab-grid">

          <div class="ap-product-tab-left">
            <h3>{{ block.settings.title }}</h3>

            <div class="ap-product-desc">
              {{ block.settings.description }}
            </div>

            {% if block.settings.list_1 != blank or block.settings.list_2 != blank or block.settings.list_3 != blank or block.settings.list_4 != blank %}
              <ul>
                {% if block.settings.list_1 != blank %}
                  <li>{{ block.settings.list_1 }}</li>
                {% endif %}

                {% if block.settings.list_2 != blank %}
                  <li>{{ block.settings.list_2 }}</li>
                {% endif %}

                {% if block.settings.list_3 != blank %}
                  <li>{{ block.settings.list_3 }}</li>
                {% endif %}

                {% if block.settings.list_4 != blank %}
                  <li>{{ block.settings.list_4 }}</li>
                {% endif %}
              </ul>
            {% endif %}
          </div>

          <div class="ap-product-tab-right">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
                width="900"
                height="700"
              >
            {% endif %}
          </div>

        </div>
      </div>
    {% endfor %}

  </div>
</section>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('.ap-product-tabs-section');

    if (!section) return;

    const buttons = section.querySelectorAll('.ap-product-tab-btn');
    const contents = section.querySelectorAll('.ap-product-tab-content');

    buttons.forEach((button) => {
      button.addEventListener('click', function () {
        const tabId = this.getAttribute('data-tab');

        buttons.forEach((btn) => btn.classList.remove('active'));
        contents.forEach((content) => content.classList.remove('active'));

        this.classList.add('active');

        const activeContent = section.querySelector('#' + tabId);

        if (activeContent) {
          activeContent.classList.add('active');
        }
      });
    });
  });
</script>


<style>
    }

    .ap-product-tab-left h3 {
      font-size: 32px;
    }

    .ap-product-tabs-heading h2 {
      font-size: 40px;
    }
  }

  @media screen and (max-width: 767px) {
    .ap-product-tabs-wrapper {
      padding: 30px 20px;
      border-radius: 20px;
    }

    .ap-product-tabs-heading h2 {
      font-size: 30px;
    }

    .ap-product-tab-left h3 {
      font-size: 26px;
    }

    .ap-product-tab-btn {
      width: 100%;
    }
  }
</style>