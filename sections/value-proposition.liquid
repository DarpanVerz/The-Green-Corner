<section class="value-proposition">
  <div class="page-width">
    <div class="vp-header d-flex justify-space-between">
     <div> 
      <p class="vp-subtitle">{{ section.settings.subtitle }}</p>
      <h2 class="vp-title">{{ section.settings.title }}</h2>
     </div>
      <div>
        <p class="vp-desc">{{ section.settings.description }}</p>
      </div>
    </div>

    <div class="vp-content">

      <div class="vp-items left">
        {% for block in section.blocks %}
          {% if block.settings.position == 'left' %}
            <div class="vp-item">
              <div class="icon">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | img_url: '100x' }}" alt="">
                {% endif %}
              </div>
              <h4>{{ block.settings.heading }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="vp-image">
        <div class="bg-shape"></div>
        {% if section.settings.main_image != blank %}
          <img src="{{ section.settings.main_image | img_url: '600x' }}" alt="">
        {% endif %}
      </div>

      <div class="vp-items right">
        {% for block in section.blocks %}
          {% if block.settings.position == 'right' %}
            <div class="vp-item">
              <div class="icon">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | img_url: '100x' }}" alt="">
                {% endif %}
              </div>
              <h4>{{ block.settings.heading }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </div>
</section>

<style>

.value-proposition {
  padding: 0;
  text-align: center;
}

.vp-header {
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px; /* optional */
    text-align: left;
}

.vp-subtitle {
  letter-spacing: 4px;
  color: #056839;
  font-size: 17px;
  font-family: 'didotbold';
}

.vp-title {
  font-size: 50px;
  margin: 10px 0;
  color:#1A1A1A;
   font-family: 'didotregular';
}

.vp-desc {
  color: #595959;
      font-size: 16px;
    line-height: 25px;
}

.vp-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 30px;
  position:relative;
}

.vp-items {
  width: 25%;
}

.vp-item {
  margin-bottom: 100px;
}

.vp-items.left:after {
    content: "";
    background-color: #e7e7e7;
    width: 100%;
    height: 1px;
    position: absolute;
    margin-top: 20px;
    bottom: 55%;
}


.vp-items.right .vp-item:after {
    content: "";
    border-bottom: 1px solid #d2d2d2;
    width: 27%;
    position: absolute;
    margin-top: 20px;
    mask-repeat: unset;
    right: 145px;
}

.vp-items.right { padding-top:50px; }

.vp-items.left { text-align: left; padding-top:50px; }

.vp-items.left .icon {
    display: flex;
    justify-content: start;
    margin: 0 auto 20px 0;
}

.vp-items.right .icon {
    display: flex;
    justify-content: end;
    margin: 0 0 20px auto;
}

.vp-item .icon {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin: 0 auto 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vp-item .icon img {
  width: 50px;
  height: 50px;
}

.vp-item h4 {
  font-size: 18px;
  margin-bottom: 5px;
  color: #1A1A1A;
  font-weight: 500;
  font-family:Montserrat, sans-serif;
}

.vp-item p {
  font-size: 16px;
  color: #595959;
}

.vp-image {
  position: relative;
  width: 40%;
}

.vp-image img {
  width: 100%;
  position: relative;
  z-index: 2;
  padding-bottom: -6px !important;
}

.bg-shape {
  position: absolute;
  width: 100%;
  height: 70%;
  background: #8bc34a;
  border-radius: 200px 200px 0 0;
  bottom: 0;
  z-index: 1;
}

/* RESPONSIVE */
/* =========================
   TABLET VIEW
========================= */

@media screen and (min-width: 750px) {
    .value-proposition .page-width {
        padding: 0 8rem;
    }
}

@media screen and (max-width: 1024px) {

  .vp-header {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 15px;
  }

  .vp-content {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .vp-items {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .vp-items.left,
  .vp-items.right {
    text-align: center;
  }

  .vp-items.left .icon,
  .vp-items.right .icon {
    justify-content: center;
    margin: 0 auto 15px;
  }

  .vp-item {
    margin-bottom: 0;
  }

  .vp-image {
    width: 70%;
    margin: 0 auto;
    order: 3;
  }

  .vp-title {
    font-size: 40px;
  }
}


/* =========================
   MOBILE VIEW
========================= */

@media screen and (max-width: 767px) {

  .vp-header {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 10px;
  }

  .vp-subtitle {
    font-size: 14px;
    letter-spacing: 2px;
  }

  .vp-title {
    font-size: 30px;
    line-height: 38px;
  }

  .vp-desc {
    font-size: 15px;
    line-height: 24px;
  }

  .vp-content {
    flex-direction: column;
    gap: 20px;
  }

  .vp-items {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .vp-items.left,
  .vp-items.right {
    text-align: center;
  }

  .vp-items.left .icon,
  .vp-items.right .icon {
    justify-content: center;
    margin: 0 auto 15px;
  }

  .vp-item h4 {
    font-size: 20px;
  }

  .vp-item p {
    font-size: 15px;
    line-height: 24px;
  }

  .vp-image {
    width: 100%;
    margin-top: 20px;
    order: 3;
  }

  .bg-shape {
    height: 75%;
  }

  .vp-items.left:after { display:none; }
}
</style>

{% schema %}
{
  "name": "Value Proposition",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "VALUE PROPOSITION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Makes Us Unique"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Describe your brand here"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Center Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Value Proposition",
      "category": "Custom"
    }
  ]
}
{% endschema %}